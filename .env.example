# Accessiflow — Environment Configuration
# Copy to .env and fill in your values.

# Required: Your Canvas LMS instance URL
ACCESSIFLOW_CANVAS_BASE_URL=https://canvas.yourschool.edu

# Required: Canvas API access token (generate in Canvas → Settings → New Access Token)
ACCESSIFLOW_CANVAS_API_TOKEN=

# Optional: Output directory for reports
ACCESSIFLOW_OUTPUT_DIR=output

# Optional: Max file size to check (MB)
ACCESSIFLOW_MAX_FILE_SIZE_MB=50

# ─── AI Provider (Optional — BYO Key) ─────────────────────────
# Supported providers: anthropic, openai, google, grok
ACCESSIFLOW_AI_PROVIDER=

# API key for your chosen provider
ACCESSIFLOW_AI_API_KEY=

# Optional: Override the default model
# Defaults: anthropic/claude-sonnet-4-20250514, gpt-4o, gemini/gemini-2.0-flash, openai/grok-3
ACCESSIFLOW_AI_MODEL=
