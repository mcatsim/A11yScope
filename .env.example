# A11yScope v2.0 — Environment Configuration
# Copy to .env and fill in your values.

# ─── Canvas LMS ───────────────────────────────────────────────
# Required: Your Canvas LMS instance URL
A11YSCOPE_CANVAS_BASE_URL=https://canvas.yourschool.edu

# Required (auth_mode=none) or Optional (auth_mode=local/sso):
# Canvas API access token (generate in Canvas → Settings → New Access Token)
A11YSCOPE_CANVAS_API_TOKEN=

# Shared Canvas token for all users (optional, for auth_mode=local/sso)
A11YSCOPE_SHARED_CANVAS_TOKEN=

# Optional: Output directory for reports
A11YSCOPE_OUTPUT_DIR=output

# Optional: Max file size to check (MB)
A11YSCOPE_MAX_FILE_SIZE_MB=50

# ─── Authentication ───────────────────────────────────────────
# Auth mode: none (default, v1 behavior) | local (email+password) | sso
A11YSCOPE_AUTH_MODE=none

# Secret key for JWT signing (required for local/sso; auto-generated for none)
A11YSCOPE_SECRET_KEY=

# Database URL (SQLite default, PostgreSQL optional)
A11YSCOPE_DATABASE_URL=sqlite+aiosqlite:///data/a11yscope.db

# Default admin user (seeded on first boot when auth_mode != none)
A11YSCOPE_ADMIN_EMAIL=admin@localhost
A11YSCOPE_ADMIN_PASSWORD=change-me

# ─── SSO (only when auth_mode=sso) ───────────────────────────
# Protocol: oidc | saml
A11YSCOPE_SSO_PROTOCOL=oidc

# OIDC settings
A11YSCOPE_SSO_OIDC_DISCOVERY_URL=
A11YSCOPE_SSO_OIDC_CLIENT_ID=
A11YSCOPE_SSO_OIDC_CLIENT_SECRET=

# SAML settings
A11YSCOPE_SSO_SAML_METADATA_URL=
A11YSCOPE_SSO_SAML_ENTITY_ID=

# SSO user defaults
A11YSCOPE_SSO_DEFAULT_ROLE=auditor
A11YSCOPE_SSO_AUTO_CREATE_USERS=true

# ─── AI Provider (Optional — BYO Key) ─────────────────────────
# Supported providers: anthropic, openai, google, grok
A11YSCOPE_AI_PROVIDER=

# API key for your chosen provider
A11YSCOPE_AI_API_KEY=

# Optional: Override the default model
# Defaults: anthropic/claude-sonnet-4-20250514, gpt-4o, gemini/gemini-2.0-flash, openai/grok-3
A11YSCOPE_AI_MODEL=
